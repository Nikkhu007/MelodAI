# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ──────────────────────────────────────────────────
# Get free cluster at: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/melodai?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRE=7d

# ── Cloudinary (for audio/image uploads) ──────────────────────────
# Get free account at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Frontend URL (your Vercel deployment URL) ──────────────────────
CLIENT_URL=https://melodai.vercel.app

# ── AI Service URL (Render deployment URL) ─────────────────────────
AI_SERVICE_URL=https://melodai-ai.onrender.com

# ── YouTube (local dev only — set to false in production) ──────────
ENABLE_YOUTUBE=false

# ── Anthropic Claude API (for AI lyrics generation when lyrics not found) ──
# Get free API key at: https://console.anthropic.com
# Leave blank to disable AI lyrics generation
ANTHROPIC_API_KEY=
